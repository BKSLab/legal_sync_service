# --- Приложение ---
APP_NAME=Legal Sync Service
API_V1_PREFIX=/api/v1
LOGGING_CONFIG_PATH=logging.ini

# --- База данных (Postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_NAME=legal_sync_service_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# --- Админка (sqladmin) ---
SECRET_KEY=your_secret_key_for_admin_sessions
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_SESSION_HTTPS_ONLY=false

# --- Авторизация служебного REST API ---
API_KEY=your_legal_sync_service_api_key

# --- publication.pravo.gov.ru ---
PUBLICATION_PRAVO_BASE_URL=https://publication.pravo.gov.ru
PUBLICATION_PRAVO_TIMEOUT_SECONDS=30

# --- RAG Service ---
RAG_SERVICE_BASE_URL=http://localhost:8001
RAG_SERVICE_API_KEY=your_rag_service_api_key
RAG_SERVICE_TIMEOUT_SECONDS=60

# --- Планировщик ---
SCHEDULER_ENABLED=true
MONITORING_CRON_HOUR=3
PROCESSING_CRON_HOUR=4
TIMEZONE=Europe/Moscow

# --- Запуск ---
RUN_MIGRATIONS_ON_START=true
HYPERCORN_WORKERS=2
